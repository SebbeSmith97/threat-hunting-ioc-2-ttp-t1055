## 3. KQL query

```kql
// Hunt T1055.001-H01 ‚Äî Classical DLL injection
// Hypothesis: cross-process memory write + remote thread creation + image load
// in the target process, all within a short window from the same initiator

// Step 1 ‚Äî cross-process memory writes (VirtualAllocEx + WriteProcessMemory)
let cross_process_writes =
    DeviceEvents
    | where Timestamp > ago(7d)
    | where ActionType == "WriteProcessMemoryApiCall"
    | where InitiatingProcessId != ProcessId          // truly cross-process, not self-write
    | project WriteTime = Timestamp,
              DeviceId,
              DeviceName,
              WriterPid = InitiatingProcessId,
              WriterFile = InitiatingProcessFileName,
              WriterCommandLine = InitiatingProcessCommandLine,
              TargetPid = ProcessId,
              TargetFile = FileName;

// Step 2 ‚Äî correlate with remote thread creation in the same target (CreateRemoteThread)
let with_remote_threads =
    cross_process_writes
    | join kind=inner (
        DeviceEvents
        | where Timestamp > ago(7d)
        | where ActionType == "CreateRemoteThreadApiCall"
        | project ThreadTime = Timestamp,
                  DeviceId,
                  WriterPid = InitiatingProcessId,
                  TargetPid = ProcessId
    ) on DeviceId, WriterPid, TargetPid
    | where datetime_diff('second', ThreadTime, WriteTime) between (0 .. 60);  // same sequence window

// Step 3 ‚Äî correlate with subsequent image load in the target (LoadLibrary effect)
let full_chain =
    with_remote_threads
    | join kind=inner (
        DeviceImageLoadEvents
        | where Timestamp > ago(7d)
        | project LoadTime = Timestamp,
                  DeviceId,
                  TargetPid = InitiatingProcessId,
                  LoadedFile = FileName,
                  FolderPath,
                  IsSigned,
                  Signer
    ) on DeviceId, TargetPid
    | where datetime_diff('second', LoadTime, ThreadTime) between (0 .. 60);  // load follows thread

// Step 4 ‚Äî prevalence filter and aggregation per writer-target-DLL combination
full_chain
| summarize
    Devices    = dcount(DeviceId),
    Events     = count(),
    FirstSeen  = min(WriteTime),
    LastSeen   = max(LoadTime),
    IsSigned   = take_any(IsSigned),
    Signer     = take_any(Signer),
    WriterCLI  = take_any(WriterCommandLine)
    by WriterFile, TargetFile, LoadedFile, FolderPath
| where Devices <= 5                                  // tune this threshold per tenant baseline
| order by Devices asc, Events desc
```

**How to read this query:**

- `| where ActionType == "WriteProcessMemoryApiCall"` ‚Äî keeps only rows where one process
  wrote into another process's memory. This is the first step of classical DLL injection.
- `| join kind=inner (...)` ‚Äî links the memory-write events to thread-creation events that
  happened within 60 seconds in the same process pair. This eliminates benign memory writers
  who never create threads.
- The second join adds the image-load event ‚Äî the DLL actually appearing in the target. All
  three events must occur in sequence for a row to appear in the output.
- `dcount(DeviceId)` counts how many different machines show this writer‚Üítarget‚ÜíDLL
  combination. Low device counts (‚â§ 5) suggest something rare and potentially targeted.
  High device counts suggest something deployed widely ‚Äî investigate separately.
- `| order by Devices asc` surfaces the rarest combinations first.

